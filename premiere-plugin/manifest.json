{
  "manifestVersion": 5,
  "id": "com.sridhar.syncx",
  "name": "Sync-X",
  "version": "2.1.0",
  "main": "index.html",
  "host": {
    "app": "premierepro",
    "minVersion": "25.6.0"
  },
  "requiredPermissions": {
    "clipboard": "read",
    "localFileSystem": "fullAccess",
    "network": {
      "domains": "all"
    },
    "webview": {
      "allow": "yes",
      "domains": [],
      "allowLocalRendering": "yes",
      "enableMessageBridge": "localOnly"
    },
    "allowCodeGenerationFromStrings": false
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "syncXPanel",
      "label": {
        "default": "Sync-X"
      },
      "minimumSize": {
        "width": 320,
        "height": 480
      },
      "preferredDockedSize": {
        "width": 400,
        "height": 720
      },
      "preferredFloatingSize": {
        "width": 420,
        "height": 760
      }
    }
  ]
}
